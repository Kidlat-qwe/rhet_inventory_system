PORT=3000
NODE_ENV=development
# Comma-separated origins for CORS (Vite may use 5173 or 5174 locally)
FRONTEND_URL=http://localhost:5173,http://localhost:5174

DB_HOST_DEVELOPMENT=ep-xxxxx.ap-southeast-1.aws.neon.tech
DB_PORT_DEVELOPMENT=5432
DB_NAME_DEVELOPMENT=your_database
DB_USER_DEVELOPMENT=your_user
DB_PASSWORD_DEVELOPMENT=your_password
DB_SSL_DEVELOPMENT=true

# Optional production overrides when NODE_ENV=production
# DB_HOST_PRODUCTION=
# DB_PORT_PRODUCTION=5432
# DB_NAME_PRODUCTION=
# DB_USER_PRODUCTION=
# DB_PASSWORD_PRODUCTION=
# DB_SSL_PRODUCTION=true

# Firebase Admin SDK — line-by-line from the service account JSON (preferred for Coolify)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk%40your-project.iam.gserviceaccount.com
FIREBASE_API_KEY=your-web-api-key

# Optional: base64 of the full PEM private key (recommended on Coolify if \n is mangled)
# FIREBASE_PRIVATE_KEY_BASE64=

# Optional local JSON fallback if FIREBASE_* env vars are not set
# FIREBASE_SERVICE_ACCOUNT_PATH=src/config/your-firebase-adminsdk.json

# Local development only. Never enable in a deployed environment.
AUTH_BYPASS=false

# Optional webhook fallback when external systems omit webhookUrl on stock-requests.
# Per-system API keys are managed in RHET UI → API Keys (not env).
PSMS_WEBHOOK_URL=http://localhost:5000/api/webhooks/inventory
