PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

DB_HOST_DEVELOPMENT=ep-xxxxx.ap-southeast-1.aws.neon.tech
DB_PORT_DEVELOPMENT=5432
DB_NAME_DEVELOPMENT=your_database
DB_USER_DEVELOPMENT=your_user
DB_PASSWORD_DEVELOPMENT=your_password
DB_SSL_DEVELOPMENT=true

# Optional production overrides when NODE_ENV=production
# DB_HOST_PRODUCTION=
# DB_PORT_PRODUCTION=5432
# DB_NAME_PRODUCTION=
# DB_USER_PRODUCTION=
# DB_PASSWORD_PRODUCTION=
# DB_SSL_PRODUCTION=true

# Prefer a local Firebase Admin SDK JSON (gitignored). Path is relative to backend/.
FIREBASE_SERVICE_ACCOUNT_PATH=src/config/rhet-inventory-firebase-adminsdk-fbsvc-e933f0dc86.json

# Optional fallback if the JSON file is not present:
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# PSMS integration (machine-to-machine)
PSMS_INTEGRATION_KEY=change-me-to-a-long-random-secret
# Optional default webhook when PSMS does not send webhookUrl per request
PSMS_WEBHOOK_URL=http://localhost:5000/api/webhooks/inventory
